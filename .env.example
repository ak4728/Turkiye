# Copy this file to .env and fill in your real credentials.
# .env is gitignored and must never be committed.
#
# PostgreSQL connection string.
# URL-encode special characters in the password (e.g. @ -> %40, ! -> %21).
# If your server requires SSL, append ?sslmode=require to the URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/travelsite"
